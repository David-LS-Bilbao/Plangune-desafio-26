// Prisma schema · DESAFIO-26 (PostgreSQL)
//
// Espejo COMPLETO de la base de datos real: docs/data/schema-real/init.sql.
// Nombres de campo en snake_case = columnas reales; `@@map` mapea cada modelo a su tabla.
//
// IMPORTANTE:
// - El runtime sigue en MOCK (no se consulta PostgreSQL todavía, ADR-0001). Este schema es
//   modelo/documentación + preparación; NO se han ejecutado migraciones (`prisma migrate`).
// - `onDelete` replica init.sql (CASCADE / SET NULL). `onUpdate` en init.sql es NO ACTION;
//   se deja el valor por defecto de Prisma (la tarea solo exige respetar `onDelete`).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// users — usuarios (familiares y de negocio comparten tabla, distinguidos por `role`).
model User {
  id       Int    @id @default(autoincrement())
  email    String @unique @db.VarChar(100)
  password String @db.VarChar(255)
  role     String @db.VarChar(20)

  business                 Business?
  families                 Family[]
  plans                    Plan[]
  favorite_events          UserFavoriteEvent[]
  favorite_plans           UserFavoritePlan[]
  selected_recommendations UserSelectedRecommendation[]

  @@map("users")
}

/// families — una familia pertenece a un usuario.
model Family {
  id          Int    @id @default(autoincrement())
  user_id     Int
  family_name String @db.VarChar(100)

  user    User           @relation(fields: [user_id], references: [id], onDelete: Cascade)
  members FamilyMember[]

  @@map("families")
}

/// family_members — miembros de una familia (solo edad, sin datos sensibles de menores).
model FamilyMember {
  id        Int     @id @default(autoincrement())
  family_id Int
  name      String? @db.VarChar(100)
  age       Int

  family Family @relation(fields: [family_id], references: [id], onDelete: Cascade)

  @@map("family_members")
}

/// businesses — un negocio pertenece a un usuario (relación 1:1 por `user_id` único).
model Business {
  id           Int     @id @default(autoincrement())
  user_id      Int     @unique
  name         String  @db.VarChar(100)
  address      String?
  phone_number String? @db.VarChar(30)
  plan         Int? // entero suelto en init.sql (NO es FK)

  user   User    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  events Event[]
  offers Offer[]

  @@map("businesses")
}

/// events — entidad central. Espejo de la tabla `events` de init.sql.
model Event {
  id              Int       @id @default(autoincrement())
  business_id     Int?
  fuente          String?   @db.VarChar(20)
  external_id     String?
  title           String    @db.VarChar(150)
  description     String?
  categoria       String?   @db.VarChar(50)
  tipo_plantilla  String?   @db.VarChar(100)
  municipio       String?   @db.VarChar(100)
  territorio      String?   @db.VarChar(30)
  address         String?
  lat             Decimal?  @db.Decimal(9, 6)
  lng             Decimal?  @db.Decimal(9, 6)
  telefono        String?   @db.VarChar(30)
  email           String?   @db.VarChar(100)
  website         String?
  es_lluvia       Boolean   @default(false)
  es_carrito      Boolean   @default(false)
  es_cambiador    Boolean   @default(false)
  es_silla_ruedas Boolean   @default(false)
  es_mascotas     Boolean   @default(false)
  edad_minima     Decimal?  @db.Decimal
  multiplicador   Decimal?  @default(1.00) @db.Decimal(3, 2)
  fecha_inicio    DateTime  @db.Timestamp(6)
  fecha_fin       DateTime? @db.Timestamp(6)
  lugar           String?   @db.VarChar(255)
  price           String?   @db.VarChar
  imagen_url      String?
  tipo_evento     String?   @db.VarChar(100)

  business                 Business?                    @relation(fields: [business_id], references: [id], onDelete: SetNull)
  plan_events              PlanEvent[]
  favorite_events          UserFavoriteEvent[]
  selected_recommendations UserSelectedRecommendation[]

  // Índices declarativos para los filtros de /api/events (no presentes en init.sql).
  @@index([municipio])
  @@index([territorio])
  @@index([categoria])
  @@index([tipo_evento])
  @@index([fecha_inicio])
  @@map("events")
}

/// offers — ofertas de un negocio.
model Offer {
  id          Int      @id @default(autoincrement())
  business_id Int
  title       String   @db.VarChar(150)
  discount    String?  @db.VarChar(50)
  description String?
  duration    Decimal? @db.Decimal

  business Business @relation(fields: [business_id], references: [id], onDelete: Cascade)

  @@map("offers")
}

/// plans — planes/itinerarios; `creator_id` opcional (SET NULL al borrar el usuario).
model Plan {
  id                Int     @id @default(autoincrement())
  creator_id        Int?
  title             String  @db.VarChar(150)
  is_recommendation Boolean @default(false)
  rating            Int?

  creator        User?              @relation(fields: [creator_id], references: [id], onDelete: SetNull)
  plan_events    PlanEvent[]
  favorite_plans UserFavoritePlan[]

  @@map("plans")
}

/// plan_events — eventos de un plan (PK compuesta plan_id + event_id).
model PlanEvent {
  plan_id     Int
  event_id    Int
  event_order Int

  plan  Plan  @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  event Event @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@id([plan_id, event_id])
  @@map("plan_events")
}

/// user_favorite_events — eventos favoritos de un usuario (PK compuesta user_id + event_id).
model UserFavoriteEvent {
  user_id  Int
  event_id Int
  saved_at DateTime? @default(now()) @db.Timestamp(6)

  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  event Event @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@id([user_id, event_id])
  @@map("user_favorite_events")
}

/// user_favorite_plans — planes favoritos de un usuario (PK compuesta user_id + plan_id).
model UserFavoritePlan {
  user_id  Int
  plan_id  Int
  saved_at DateTime? @default(now()) @db.Timestamp(6)

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [plan_id], references: [id], onDelete: Cascade)

  @@id([user_id, plan_id])
  @@map("user_favorite_plans")
}

/// user_selected_recommendations — recomendaciones elegidas (PK compuesta user_id + event_id).
model UserSelectedRecommendation {
  user_id     Int
  event_id    Int
  selected_at DateTime? @default(now()) @db.Timestamp(6)

  user  User  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  event Event @relation(fields: [event_id], references: [id], onDelete: Cascade)

  @@id([user_id, event_id])
  @@map("user_selected_recommendations")
}
