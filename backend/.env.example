# backend/.env.example
# Copia a backend/.env (no commitear). Valores de ejemplo, NO reales.

PORT=3000
NODE_ENV=development

# PostgreSQL vía Prisma (preparado, aún sin modelos ni features).
# El healthcheck funciona aunque no haya DB real disponible.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/desafio26_dev?schema=public

# Auth (no implementado todavía; reservado para futuras ramas)
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

# CORS / cliente
CLIENT_URL=http://localhost:5173
