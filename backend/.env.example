# backend/.env.example
# Copia a backend/.env (no commitear). Valores de ejemplo, NO reales.

PORT=3000
NODE_ENV=development

# PostgreSQL vía Prisma. Credenciales de desarrollo local alineadas con compose.yaml
# (servicio postgres: usuario desafio26 / db desafio26_dev). NO son secretos reales.
DATABASE_URL="postgresql://desafio26:desafio26_dev_password@localhost:5434/desafio26_dev?schema=public"

# Auth (login real con JWT + cookie httpOnly). Cambia JWT_SECRET por un valor largo y aleatorio
# de 32+ caracteres en tu .env local; NO lo commitees. El placeholder se rechaza en runtime.
JWT_SECRET=replace_with_32_plus_random_chars
JWT_EXPIRES_IN=7d

# CORS / cliente
CLIENT_URL=http://localhost:5173

# Proxy inverso (Nginx Proxy Manager en el VPS).
#   - Local/desarrollo: 0
#   - Producción detrás de NPM: 1  → req.ip y el rate limit usan la IP real del cliente
#     (no la del proxy). Sin esto, el rate limit contaría a todos como una sola IP.
TRUST_PROXY=0

# Rate limiting (defaults razonables para demo; se OMITE en tests). Todo opcional:
#   - Global /api:               120 req / 60 s por IP.
#   - Asistente (family-plan):    10 req / 60 s por IP (puede tocar LLM/API externa: coste).
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=120
ASSISTANT_RATE_LIMIT_WINDOW_MS=60000
ASSISTANT_RATE_LIMIT_MAX=10
# Nota: /api/events está paginado con límite duro (page/limit; por defecto 20, máximo 50).

# Data Recommender (API Flask del equipo Data) — recomendador principal de /api/recommendations.
# Contrato real: POST {DATA_API_URL}/recomendar { id_user, consulta, filtros }.
# Si está deshabilitado o falla, el backend usa el recomendador local (fallback).
# Por defecto false: permite desarrollar con fallback local si Data no está levantado.
# Con Docker (compose.yaml) el backend ya apunta a http://data-recommender:5000.
# Sin Docker: Windows/Linux DATA_API_URL=http://localhost:5000 · Mac (AirPlay ocupa 5000) :5050
DATA_RECOMMENDER_ENABLED=false
DATA_API_URL=http://localhost:5000
DATA_API_TIMEOUT_MS=4000
# id_user que se envía a Data. Sin auth todavía: 0 = sesión anónima (sin historial; Data
# degrada a recomendación semántica pura). Cambiar solo si Data exige un id concreto.
DATA_USER_ID=0

# Asistente LLM/chatbot Data (GUNI) — asistente conversacional de /api/assistant/family-plan.
# Si está deshabilitado o falla, el backend usa cloud (Gemini) o el fallback local sin IA.
# Por defecto false: el chatbot + Ollama son PESADOS (modelo qwen2.5-coder) y opt-in.
#   - Con Docker (profile chat): docker compose --profile chat up; usar
#       LLM_ASSISTANT_API_URL=http://data-chatbot:5000   (puerto interno del servicio)
#   - Sin Docker (Ollama en local): LLM_ASSISTANT_API_URL=http://localhost:5001
LLM_ASSISTANT_ENABLED=false
LLM_ASSISTANT_API_URL=http://localhost:5001
LLM_ASSISTANT_TIMEOUT_MS=30000
# Contrato del asistente LLM:
#   - get-question     → chatbot Data dockerizado: GET ${LLM_ASSISTANT_API_URL}/<pregunta>
#   - post-family-plan → ai-service Flask histórico: POST /assistant/family-plan
# Objetivo actual: consumir el chatbot Docker de Data.
LLM_ASSISTANT_CONTRACT=get-question

# Cloud assistant fallback (proveedor cloud opcional para GUNI, p. ej. Gemini).
# Aún NO cableado en assistant.service.js (cliente aislado). La API key vive SOLO en backend:
# nunca usar variables VITE_* para esto ni exponerla al frontend. NO commitear claves reales.
CLOUD_ASSISTANT_ENABLED=false
CLOUD_ASSISTANT_PROVIDER=gemini
CLOUD_ASSISTANT_API_KEY=
CLOUD_ASSISTANT_MODEL=gemini-2.5-flash
CLOUD_ASSISTANT_TIMEOUT_MS=7000

# Logging (info, debug, warn, error)
LOG_LEVEL=info
\n# Google OAuth\nGOOGLE_CLIENT_ID=TU_GOOGLE_CLIENT_ID
