# backend/.env.example
# Copia a backend/.env (no commitear). Valores de ejemplo, NO reales.

PORT=3000
NODE_ENV=development

# PostgreSQL vía Prisma. Credenciales de desarrollo local alineadas con compose.yaml
# (servicio postgres: usuario desafio26 / db desafio26_dev). NO son secretos reales.
DATABASE_URL="postgresql://desafio26:desafio26_dev_password@localhost:5434/desafio26_dev?schema=public"

# Auth (login real con JWT + cookie httpOnly). Cambia JWT_SECRET por un valor largo y aleatorio
# de 32+ caracteres en tu .env local; NO lo commitees. El placeholder se rechaza en runtime.
JWT_SECRET=replace_with_32_plus_random_chars
JWT_EXPIRES_IN=7d

# CORS / cliente
CLIENT_URL=http://localhost:5173

# Data Recommender (API Flask del equipo Data) — recomendador principal de /api/recommendations.
# Si está deshabilitado o falla, el backend usa el recomendador local (fallback).
# Por defecto false: permite desarrollar con fallback local si Data no está levantado.
# Windows/Linux: DATA_API_URL=http://localhost:5000
# Mac: si AirPlay/Control Center ocupa 5000, usar DATA_API_URL=http://localhost:5050
DATA_RECOMMENDER_ENABLED=false
DATA_API_URL=http://localhost:5000
DATA_API_TIMEOUT_MS=2000

# Asistente LLM/chatbot Data (puerto 5001) — asistente conversacional de /api/assistant/family-plan.
# Si está deshabilitado o falla, el backend usa el fallback local (sin IA).
# Por defecto false: requiere Ollama + el modelo qwen2.5-coder:latest corriendo en local.
# Para demo local, poner true. NO usar el puerto 5000 (reservado para la Data API).
LLM_ASSISTANT_ENABLED=false
LLM_ASSISTANT_API_URL=http://localhost:5001
LLM_ASSISTANT_TIMEOUT_MS=8000
# Contrato del asistente LLM:
#   - get-question     → chatbot Data dockerizado: GET ${LLM_ASSISTANT_API_URL}/<pregunta>
#   - post-family-plan → ai-service Flask histórico: POST /assistant/family-plan
# Objetivo actual: consumir el chatbot Docker de Data.
LLM_ASSISTANT_CONTRACT=get-question

# Cloud assistant fallback (proveedor cloud opcional para GUNI, p. ej. Gemini).
# Aún NO cableado en assistant.service.js (cliente aislado). La API key vive SOLO en backend:
# nunca usar variables VITE_* para esto ni exponerla al frontend. NO commitear claves reales.
CLOUD_ASSISTANT_ENABLED=false
CLOUD_ASSISTANT_PROVIDER=gemini
CLOUD_ASSISTANT_API_KEY=
CLOUD_ASSISTANT_MODEL=gemini-2.5-flash
CLOUD_ASSISTANT_TIMEOUT_MS=7000

# Logging (info, debug, warn, error)
LOG_LEVEL=info
