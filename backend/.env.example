# backend/.env.example
# Copia a backend/.env (no commitear). Valores de ejemplo, NO reales.

PORT=3000
NODE_ENV=development

# PostgreSQL vía Prisma (preparado para uso futuro).
# Sin DATABASE_URL, el backend usa mock en memoria (desarrollo local).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/desafio26_dev?schema=public

# Data API (recomendador externo, futuro)
# Deshabilitado por defecto. Si se activa y falla, fallback a recomendador local.
DATA_RECOMMENDER_ENABLED=false
DATA_API_URL=http://localhost:5000
DATA_API_TIMEOUT_MS=2000

# Auth (no implementado todavía; reservado para futuras ramas)
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

# CORS / cliente
CLIENT_URL=http://localhost:5173

# Data Recommender (API Flask del equipo Data) — recomendador principal de /api/recommendations.
# Si está deshabilitado o falla, el backend usa el recomendador local (fallback).
# Por defecto false: la API de Data aún no corre en local (pendiente de dockerizar).
DATA_RECOMMENDER_ENABLED=false
DATA_API_URL=http://localhost:5000
DATA_API_TIMEOUT_MS=2000

# Asistente LLM local (ai-service Flask, puerto 5001) — asistente conversacional de /api/assistant/family-plan.
# Si está deshabilitado o falla, el backend usa el fallback local (sin IA).
# Por defecto false: requiere Ollama + el modelo qwen2.5-coder:latest corriendo en local.
# Para demo local, poner true. NO usar el puerto 5000 (reservado para la Data API).
LLM_ASSISTANT_ENABLED=false
LLM_ASSISTANT_API_URL=http://localhost:5001
LLM_ASSISTANT_TIMEOUT_MS=8000

# Logging (info, debug, warn, error)
LOG_LEVEL=info
