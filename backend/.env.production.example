# backend/.env.production.example
# Plantilla de PRODUCCIÓN (VPS). Copiar a backend/.env.production (NO versionado) y rellenar
# con valores REALES. NUNCA commitear backend/.env.production. Aquí solo hay placeholders.

NODE_ENV=production
PORT=3000

# Detrás de Nginx Proxy Manager (IP real para rate limit / logs).
TRUST_PROXY=1
CLIENT_URL=https://<tu-dominio>

# PostgreSQL (servicio interno Docker; credenciales reales fuera del repo).
DATABASE_URL=postgresql://<user>:<password>@postgres:5432/<db>?schema=public

# Auth — generar fuerte (>=32 chars):  openssl rand -base64 48
JWT_SECRET=<generate_strong_secret_min_32_chars>
JWT_EXPIRES_IN=7d

# Rate limiting (opcional; defaults razonables para demo).
API_RATE_LIMIT_MAX=120
ASSISTANT_RATE_LIMIT_MAX=10

# ─── Data Recommender (servicio interno Docker) ───────────────────────────────────────
# El backend llama al recomendador por su NOMBRE DE SERVICIO en la red interna Docker.
# Contrato real: POST http://data-recommender:5000/recomendar { id_user, consulta, filtros }.
# NUNCA IP pública, dominio, localhost ni puerto publicado.
# compose.prod.yaml ya levanta data-recommender y deja DATA_RECOMMENDER_ENABLED=true; este
# .env puede sobrescribirlo. Si Data cae, el backend usa el fallback local reglado.
DATA_RECOMMENDER_ENABLED=true
DATA_API_URL=http://data-recommender:5000
DATA_API_TIMEOUT_MS=4000
# id_user enviado a Data. Sin auth: 0 = sesión anónima (recomendación semántica sin historial).
DATA_USER_ID=0

# ─── Asistente cloud GUNI (Gemini) ────────────────────────────────────────────────────
# La API key vive SOLO en backend, nunca en variables VITE_* del frontend.
CLOUD_ASSISTANT_ENABLED=true
CLOUD_ASSISTANT_PROVIDER=gemini
CLOUD_ASSISTANT_API_KEY=<gemini_api_key>
CLOUD_ASSISTANT_MODEL=gemini-2.5-flash
CLOUD_ASSISTANT_TIMEOUT_MS=15000

# ─── Chatbot Data + Ollama · DIFERIDO (overlay opcional) ──────────────────────────────
# No habilitar en la demo: GUNI usa Gemini (arriba). El chatbot local es pesado (Ollama) y
# usa eval() (riesgo). Se levanta aparte con compose.data.prod.yaml. Para activarlo, además
# de ese overlay, descomentar y recrear el backend:
# LLM_ASSISTANT_ENABLED=true
# LLM_ASSISTANT_CONTRACT=get-question
# LLM_ASSISTANT_API_URL=http://data-chatbot:5000
# LLM_ASSISTANT_TIMEOUT_MS=30000
