{
  "name": "desafio-26",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo DESAFIO-26 (nombre de la app provisional, lo define Marketing).",
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace frontend",
